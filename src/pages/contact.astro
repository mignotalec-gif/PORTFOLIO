---
import Base from '../layouts/Base.astro';
---
<Base title="Contact — Alec" description="Travaillons ensemble.">
  <main class="page-contact">
    <h1 class="contact-title">Travaillons ensemble.</h1>
    <p class="contact-intro">
      Je suis disponible pour des missions où la dimension technique
      et la dimension humaine sont toutes deux nécessaires.
    </p>
    <p class="contact-email">
      <a href="mailto:mignotalec@gmail.com">mignotalec@gmail.com</a>
    </p>
    <ul class="contact-offer">
      <li>Conception de produit (0 → 1)</li>
      <li>Interfaces complexes / data-driven</li>
      <li>Prototypage électronique + logiciel</li>
      <li>Recherche utilisateur & design de service</li>
    </ul>
  </main>
</Base>

<style>
  .page-contact {
    padding: var(--space-2xl) var(--space-lg);
    max-width: 680px;
    margin: 0 auto;
  }
  .contact-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-lg);
  }
  .contact-intro {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 52ch;
    line-height: 1.75;
    margin-bottom: var(--space-xl);
  }
  .contact-email a {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    cursor: pointer;
  }
  .contact-email a:hover { text-decoration: underline; }
  .contact-offer {
    margin-top: var(--space-xl);
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .contact-offer li {
    font-size: var(--text-base);
    color: var(--color-muted);
    padding-left: var(--space-lg);
    position: relative;
  }
  .contact-offer li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>
