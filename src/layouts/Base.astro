---
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Alec — Ingénieur Designer',
  description = "La technologie n'a de sens que par l'humain qu'elle sert.",
  ogImage = '/media/og.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://alec.design');
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ClientRouter />
</head>
<body>
  <slot />
  <footer class="site-footer">
    <p>Human after all. <span aria-hidden="true">—</span> Alec, {new Date().getFullYear()}</p>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/tokens.css';

  .site-footer {
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-muted);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2xl);
  }
</style>
