---
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Alec — Ingénieur Designer',
  description = "La technologie n'a de sens que par l'humain qu'elle sert.",
  ogImage = '/media/og.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://alec.design');
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ClientRouter />
</head>
<body>
  <slot />
  <footer class="site-footer">
    <div class="site-footer__inner">
      <div class="site-footer__contact">
        <p class="site-footer__heading">Me contacter</p>
        <p>Mail&nbsp;: <a href="mailto:mignotalec@gmail.com">mignotalec@gmail.com</a></p>
        <p>LinkedIn&nbsp;: <a href="https://www.linkedin.com/in/alec-mignot" target="_blank" rel="noopener">Alec Mignot</a></p>
      </div>
      <p class="site-footer__tagline">Human after all. <span aria-hidden="true">—</span> Alec, {new Date().getFullYear()}</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/tokens.css';

  .site-footer {
    padding: var(--space-xl) var(--space-lg);
    font-size: var(--text-sm);
    color: var(--color-muted);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2xl);
  }
  .site-footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }
  .site-footer__contact {
    text-align: left;
    line-height: 1.9;
  }
  .site-footer__heading {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(0,0,0,0.4);
    margin-bottom: 0.3rem;
  }
  .site-footer__contact a {
    color: rgba(0,0,0,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }
  .site-footer__contact a:hover { color: #000; }
  .site-footer__tagline {
    text-align: right;
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .site-footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .site-footer__tagline { text-align: left; }
  }
</style>
